<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.ListaTranzactiiPage"
             Title="Toate Tranzacțiile">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <CollectionView x:Name="tranzactiiList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" CornerRadius="10" Padding="10">
                            <StackLayout>
                                <Label Text="{Binding Tip}" FontAttributes="Bold"/>
                                <Label Text="{Binding Categorie}"/>
                                <Label Text="{Binding SumaAfisata}"/>
                                <Label Text="{Binding Descriere}" FontAttributes="Italic"/>
                                <Label Text="{Binding DataAfisata}" FontSize="12" TextColor="Gray"/>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
