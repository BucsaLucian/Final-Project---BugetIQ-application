<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.RaportAnualPage"
             Title="Raport Anual">

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <StackLayout Padding="10">
            <Label Text="📊 Raport Anual"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,10"/>

            <CollectionView x:Name="raportAnualListView" ItemsLayout="VerticalList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5"
                               Padding="10"
                               CornerRadius="12"
                               HasShadow="True"
                               BorderColor="{Binding SoldColor}">
                            <StackLayout>
                                <Label Text="{Binding An}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="Black"/>

                                <StackLayout Orientation="Horizontal" Spacing="5">
                                    <Label Text="📈" FontSize="16"/>
                                    <Label Text="{Binding TotalVenituri, StringFormat='Venituri: {0:0.0} RON'}"
                                           TextColor="Green"/>
                                </StackLayout>

                                <StackLayout Orientation="Horizontal" Spacing="5">
                                    <Label Text="📉" FontSize="16"/>
                                    <Label Text="{Binding TotalCheltuieli, StringFormat='Cheltuieli: {0:0.0} RON'}"
                                           TextColor="Red"/>
                                </StackLayout>

                                <StackLayout Orientation="Horizontal" Spacing="5">
                                    <Label Text="💰" FontSize="16"/>
                                    <Label Text="{Binding Sold, StringFormat='Sold: {0:0.0} RON'}"
                                           FontAttributes="Bold"
                                           TextColor="{Binding SoldColor}"/>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ScrollView>
</ContentPage>
