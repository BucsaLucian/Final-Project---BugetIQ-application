<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.DesprePage"
             Title="Despre aplicație">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Image Source="logo.png"
                   WidthRequest="120"
                   HeightRequest="120"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0" />

            <Frame CornerRadius="12" Padding="15" HasShadow="True">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#f0f4f8" Offset="0.0" />
                        <GradientStop Color="#dbe9f4" Offset="1.0" />
                    </LinearGradientBrush>
                </Frame.Background>

                <VerticalStackLayout Spacing="12">

                    <Label Text="   Această aplicație ajută utilizatorii să-și gestioneze veniturile și cheltuielile personale într-un mod simplu și eficient."
                           FontSize="14"
                           TextColor="Black" />

                    <Label Text="   Funcționalități incluse: înregistrare venituri, cheltuieli, raport lunar, raport anual, istoric tranzacții și export tranzacții."
                           FontSize="14"
                           TextColor="Black" />

                    <Label Text="🧩 Numele aplicației: BugetIQ"
                           FontSize="14" />

                    <Label Text="💻 Tehnologii: .NET MAUI, SQLite, Android Emulator"
                           FontSize="14" />

                    <Label Text="👤 Autor: Bucșa Lucian-Dumitru"
                           FontSize="14" />

                    <Label Text="📅 Anul: 2025"
                           FontSize="14" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
